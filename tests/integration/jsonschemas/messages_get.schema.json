{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accountpilot messages get <id> --json",
  "type": "object",
  "required": ["ok", "data", "error"],
  "properties": {
    "ok": { "const": true },
    "error": { "type": "null" },
    "data": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "object",
          "required": ["id", "source", "account_id", "sent_at", "direction", "people", "attachments", "email", "imessage"],
          "properties": {
            "id": { "type": "integer" },
            "source": { "type": "string" },
            "account_id": { "type": "integer" },
            "sent_at": { "type": "string" },
            "received_at": { "type": ["string", "null"] },
            "thread_id": { "type": ["string", "null"] },
            "body_text": { "type": ["string", "null"] },
            "body_html": { "type": ["string", "null"] },
            "direction": { "type": "string" },
            "subject": { "type": ["string", "null"] },
            "email": {
              "type": ["object", "null"],
              "properties": {
                "mailbox": { "type": "string" },
                "imap_uid": { "type": "integer" }
              }
            },
            "imessage": {
              "type": ["object", "null"],
              "properties": {
                "handle": { "type": ["string", "null"] },
                "chat_guid": { "type": ["string", "null"] }
              }
            },
            "people": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["role"],
                "properties": {
                  "role": { "type": "string" },
                  "id": { "type": "integer" },
                  "name": { "type": ["string", "null"] }
                }
              }
            },
            "attachments": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["filename", "mime_type", "content_hash"],
                "properties": {
                  "id": { "type": "integer" },
                  "filename": { "type": "string" },
                  "mime_type": { "type": "string" },
                  "content_hash": { "type": "string" },
                  "size_bytes": { "type": "integer" }
                }
              }
            }
          }
        }
      }
    }
  }
}
