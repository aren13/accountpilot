{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accountpilot attachments path <id> --json",
  "type": "object",
  "required": ["ok", "data", "error"],
  "properties": {
    "ok": { "const": true },
    "error": { "type": "null" },
    "data": {
      "type": "object",
      "required": ["id", "absolute_path", "exists", "size_bytes"],
      "properties": {
        "id": { "type": "integer" },
        "absolute_path": { "type": "string" },
        "exists": { "type": "boolean" },
        "size_bytes": { "type": ["integer", "null"] }
      }
    }
  }
}
