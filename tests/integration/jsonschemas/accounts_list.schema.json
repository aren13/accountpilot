{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accountpilot accounts list --json",
  "type": "object",
  "required": ["ok", "data", "error"],
  "properties": {
    "ok": { "const": true },
    "error": { "type": "null" },
    "data": {
      "type": "object",
      "required": ["accounts"],
      "properties": {
        "accounts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "source", "identifier", "enabled", "owner_id", "owner_name"],
            "properties": {
              "id": { "type": "integer" },
              "source": { "type": "string" },
              "identifier": { "type": "string" },
              "enabled": { "type": "boolean" },
              "owner_id": { "type": "integer" },
              "owner_name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
