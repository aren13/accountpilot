{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accountpilot people list --json",
  "type": "object",
  "required": ["ok", "data", "error"],
  "properties": {
    "ok": { "const": true },
    "error": { "type": "null" },
    "data": {
      "type": "object",
      "required": ["people"],
      "properties": {
        "people": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "is_owner", "identifiers", "message_count"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "surname": { "type": ["string", "null"] },
              "is_owner": { "type": "boolean" },
              "identifiers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["kind", "value"],
                  "properties": {
                    "kind": { "type": "string" },
                    "value": { "type": "string" }
                  }
                }
              },
              "message_count": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
