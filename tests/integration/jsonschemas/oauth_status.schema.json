{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accountpilot oauth status --json",
  "type": "object",
  "required": ["ok", "data", "error"],
  "properties": {
    "ok": { "const": true },
    "error": { "type": "null" },
    "data": {
      "type": "object",
      "required": ["tokens"],
      "properties": {
        "tokens": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["provider", "account_id", "secret_path", "modified_at"],
            "properties": {
              "provider": { "type": "string" },
              "account_id": { "type": "integer" },
              "secret_path": { "type": "string" },
              "modified_at": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
