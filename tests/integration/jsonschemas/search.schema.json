{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "accountpilot search <query> --json",
  "type": "object",
  "required": ["ok", "data", "error"],
  "properties": {
    "ok": { "const": true },
    "error": { "type": "null" },
    "data": {
      "type": "object",
      "required": ["query", "results"],
      "properties": {
        "query": { "type": "string" },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "source", "account_id", "sent_at", "score"],
            "properties": {
              "id": { "type": "integer" },
              "source": { "type": "string" },
              "account_id": { "type": "integer" },
              "sent_at": { "type": "string" },
              "subject": { "type": ["string", "null"] },
              "snippet": { "type": ["string", "null"] },
              "score": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
